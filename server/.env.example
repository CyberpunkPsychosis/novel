# 拷成 .env 再改值。docker compose 已用同样默认值起 postgres。
DATABASE_URL="postgresql://xumo:xumo@localhost:5432/xumo?schema=public"

# 自家 JWT 签名密钥（上线前换成随机长串：openssl rand -hex 32）
JWT_SECRET="dev-only-change-me-please"

# Apple Sign in 的 client_id：iOS App 的 bundle id，用于校验 identityToken 的 aud
# 当前 Xcode 工程的 bundle id 是 com.example.xumo；上线请改成你的真实 bundle id。
APPLE_BUNDLE_ID="com.example.xumo"

# 开发期临时邮箱登录通道（没有 Apple 开发者账号时用）。上线务必设为 false。
DEV_EMAIL_LOGIN="true"

PORT="3000"

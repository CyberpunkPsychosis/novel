{
  "name": "xumo-server",
  "version": "0.1.0",
  "private": true,
  "description": "XuMo 后端 · 里程碑1（账号 + 书/章节 + 阅读进度同步）",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@prisma/client": "^6.2.1",
    "fastify": "^5.2.0",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

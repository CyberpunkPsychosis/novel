// XuMo 里程碑1 数据模型。字段刻意与 iOS Book/Chapter/LocalUser 对齐，
// JSON 序列化即 Swift Codable。fork / 墨滴留好外键命名，里程碑2 再补表。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  appleSub       String?  @unique // Apple Sign in 的 sub；开发期邮箱通道为空
  email          String?  @unique // 开发期临时邮箱登录用
  handle         String   @unique
  penName        String
  bio            String   @default("慢慢长大的书架")
  avatarColorHex String   @default("#A65A3C")
  createdAt      DateTime @default(now())

  books        Book[]            @relation("OwnedBooks")
  progress     ReadingProgress[]
  creditTxns   CreditTxn[]
  checkin      DailyCheckin?
  notifications Notification[]
  forkRequests ForkRequest[]     @relation("Requester")
  forkUnlocks  ForkUnlock[]
  ratings      Rating[]
  purchases    Purchase[]
}

model Book {
  id              String   @id @default(cuid())
  title           String
  author          String
  blurb           String
  tags            String[]
  tagline         String
  coverColors     String[]
  coverAccent     String
  status          String
  forkOf          String? // 父书 id（里程碑2 才真正产生 fork）
  forkFromChapter Int?
  isUserCreated   Boolean  @default(false)
  ownerId          String?
  owner            User?    @relation("OwnedBooks", fields: [ownerId], references: [id])
  moderationStatus String   @default("approved") // pending / approved / rejected
  moderationReason String   @default("")
  createdAt        DateTime @default(now())

  chapters     Chapter[]
  permission   ForkPermission?
  forkRequests ForkRequest[]
  unlocks      ForkUnlock[]
  ratings      Rating[]
}

model Chapter {
  id      String @id @default(cuid())
  bookId  String
  book    Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  index   Int
  title   String
  content String

  @@unique([bookId, index])
}

model ReadingProgress {
  id           String @id @default(cuid())
  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId       String
  chapterIndex Int

  @@unique([userId, bookId])
}

// MARK: fork 生态（里程碑2）

// 每本书一份改编授权设置（作者设定；缺省视为开放、需审批、不收费）。
model ForkPermission {
  bookId          String   @id
  book            Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  allowContinue   Boolean  @default(true)
  allowAdapt      Boolean  @default(true)
  requireApproval Boolean  @default(true)
  allowDownload   Boolean  @default(true)
  priceMolDi      Int      @default(0)
}

// 改编/续写申请。
model ForkRequest {
  id          String   @id @default(cuid())
  requesterId String
  requester   User     @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  bookId      String
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  fromChapter Int
  mode        String   // "续写" / "改编"
  status      String   @default("pending") // pending / approved / denied
  createdAt   DateTime @default(now())
}

// 已解锁某本书改编/下载权的用户（付费或免费解锁后落账）。
model ForkUnlock {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}

// 墨滴流水。余额 = 该用户所有 delta 之和。
model CreditTxn {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int
  reason    String   // signup/checkin/buy/unlock/fork/royalty/refund
  note      String   @default("")
  createdAt DateTime @default(now())
}

// 每日签到状态（每用户一条）。
model DailyCheckin {
  userId   String @id
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastDate String @default("") // yyyy-MM-dd
  streak   Int    @default(0)
}

// 通知。
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // forkRequest/forkApproved/forkDenied/newBranch/checkin/system
  actor     String   @default("")
  text      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// MARK: 评分 / 充值（里程碑3）

// 用户对书评分（1..5），每用户每书一条。
model Rating {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  value     Int
  createdAt DateTime @default(now())

  @@unique([userId, bookId])
}

// StoreKit 充值记录；transactionId 唯一，保证同一笔交易只入账一次。
model Purchase {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactionId String   @unique
  productId     String
  credits       Int
  createdAt     DateTime @default(now())
}
